    "@paperback/types": "^0.8.4",
    "cheerio": "1.0.0-rc.12"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.9.2",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  }
}