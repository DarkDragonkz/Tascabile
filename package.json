{
  "name": "tascabile",
  "version": "0.1.0",
  "description": "Repository modulare di estensioni Paperback/Tascabile per manga e comics.",
  "private": true,
  "scripts": {
    "bundle": "npx paperback bundle",
    "serve": "npx paperback serve",
    "test": "npx mocha --timeout 300000 -r ts-node/register \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
