{
  "name": "tascabile",
  "version": "0.9.0",
  "description": "Repository di estensioni Paperback 0.9 mantenuta da DarkDragonkz.",
  "private": true,
  "type": "module",
  "repositoryName": "Tascabile",
  "repositoryDescription": "Repository di estensioni Paperback 0.9 mantenuta da DarkDragonkz.",
  "scripts": {
    "lint": "oxlint --type-aware --fix",
    "lint:check": "oxlint --type-aware --deny-warnings",
    "format": "oxfmt README.md package.json tsconfig.json .oxlintrc.json .oxfmtrc.json .github/workflows/build.yml src/**/*.ts",
    "format:check": "oxfmt --check README.md package.json tsconfig.json .oxlintrc.json .oxfmtrc.json .github/workflows/build.yml src/**/*.ts",
    "tsc": "tsc",
    "bundle": "paperback-cli bundle",
    "serve": "paperback-cli serve",
    "dev": "paperback-cli serve --watch",
    "test": "npm run tsc && npm run lint:check && npm run format:check && npm run bundle",
    "logcat": "paperback-cli logcat",
    "prepare": "husky"
  },
  "dependencies": {},
  "devDependencies": {
    "@paperback/toolchain": "^1.0.0-alpha.86",
    "@paperback/types": "^1.0.0-alpha.86",
    "@types/chai": "^5.2.3",
    "@types/upng-js": "^2.1.5",
    "chai": "^6.2.2",
    "cheerio": "^1.2.0",
    "fastest-levenshtein": "^1.0.16",
    "husky": "^9.1.7",
    "jpeg-js": "^0.4.4",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "stemmer": "^2.0.1",
    "typescript": "^6.0.3",
    "upng-js": "^2.1.0"
  }
}
